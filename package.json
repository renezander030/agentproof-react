{
  "name": "agentproof-react",
  "version": "0.1.1",
  "description": "CLI review gates for AI-generated React and Next.js code before it ships.",
  "type": "module",
  "bin": {
    "agentproof-react": "bin/agentproof-react.js"
  },
  "files": [
    "bin",
    "src",
    "examples",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "check": "node ./bin/agentproof-react.js check examples/good",
    "demo:bad": "node ./bin/agentproof-react.js check examples/bad",
    "demo:good": "node ./bin/agentproof-react.js check examples/good",
    "pack:dry": "npm pack --dry-run --cache ./.npm-cache",
    "test": "node ./test/run.js"
  },
  "keywords": [
    "react",
    "nextjs",
    "next-js",
    "frontend",
    "ai",
    "ai-agents",
    "ai-generated-code",
    "code-review",
    "static-analysis",
    "lint",
    "cli",
    "ci",
    "developer-tools"
  ],
  "author": "Rene Zander",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/renezander030/agentproof-react.git"
  },
  "bugs": {
    "url": "https://github.com/renezander030/agentproof-react/issues"
  },
  "homepage": "https://github.com/renezander030/agentproof-react#readme",
  "engines": {
    "node": ">=18"
  }
}
